# === Required ===

# Google OAuth Client ID (from GCP Console -> APIs & Services -> Credentials)
BOOKS_GOOGLE_CLIENT_ID=

# === Data Storage ===

# Path to data directory (database, covers, epub files)
# Default: /app/data (Docker), set to a local path for development
BOOKS_DATA_DIR=./data

# === Optional: Metadata Search ===

# Google Books API key (for metadata search when adding books)
GOOGLE_BOOKS_API_KEY=

# Hardcover.app API token (for series metadata and auto-refresh)
HARDCOVER_API_TOKEN=

# === Optional: Kindle Email (SMTP) ===

# SMTP server for sending books to Kindle devices
# Uses unauthenticated SMTP (local relay). Configure your mail server accordingly.
smtp_host=localhost
smtp_port=25
smtp_from=

# === Optional: KOReader Plugin Publishing ===

# Server URL (e.g., https://books.example.com)
BOOKS_SERVER_URL=
# Basic Auth credentials for the plugin publish endpoint (superuser required)
BOOKS_DEPLOY_USER=
BOOKS_DEPLOY_PASS=
